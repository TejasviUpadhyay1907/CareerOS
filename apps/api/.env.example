# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
DEMO_MODE=false

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection String (URI)
# Replace with your actual Supabase connection string
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Get from: Supabase → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Security ─────────────────────────────────────────────────────────────
# Use a long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (set to your Vercel frontend URL) ────────────────────────────────────
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
# Get free key from: https://openrouter.ai
CAREEROS_API_KEY=sk-or-v1-your-openrouter-key
USE_OPENROUTER=true
