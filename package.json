{
  "name": "careeros",
  "version": "1.0.0",
  "private": true,
  "description": "CareerOS - AI-Powered Career Management Platform",
  "scripts": {
    "dev:api": "cd apps/api && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "cd apps/web && npm run dev",
    "install:api": "cd apps/api && pip install -r requirements.txt",
    "install:web": "cd apps/web && npm install"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
